# Telegram Bot Configuration
# 1. Open Telegram, search for @BotFather, send /newbot, follow prompts -> get BOT_TOKEN
# 2. Start a chat with your new bot, then visit:
#    https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#    -> find "chat":{"id": <number> } -> that's your CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
TELEGRAM_CHAT_ID=123456789

# Optional: separate admin chat for error alerts (defaults to TELEGRAM_CHAT_ID)
TELEGRAM_ADMIN_CHAT_ID=

# Scheduler: hour interval between runs, business hours window (24h, local time)
RUN_EVERY_HOURS=3
BUSINESS_HOUR_START=7
BUSINESS_HOUR_END=19

# Timezone (IANA name)
TIMEZONE=Asia/Ho_Chi_Minh

# Headless browser settings
HEADLESS=true
NAV_TIMEOUT_MS=45000

# On first run, seed DB with existing articles without alerting (true/false)
SEED_ON_FIRST_RUN=true
